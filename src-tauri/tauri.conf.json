{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Atelier",
  "version": "0.1.0",
  "identifier": "com.atelier.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Atelier",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["jsx"],
        "mimeType": "text/jsx",
        "description": "React JSX Artifact"
      },
      {
        "ext": ["tsx"],
        "mimeType": "text/tsx",
        "description": "React TSX Artifact"
      }
    ]
  },
  "plugins": {
    "sql": {
      "preload": {
        "db": "sqlite:atelier.db"
      }
    }
  }
}
