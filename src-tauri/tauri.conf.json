{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Stele",
  "version": "0.2.1",
  "identifier": "com.stele.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Stele",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["jsx"],
        "mimeType": "text/jsx",
        "description": "React JSX Artifact"
      },
      {
        "ext": ["tsx"],
        "mimeType": "text/tsx",
        "description": "React TSX Artifact"
      },
      {
        "ext": ["html"],
        "mimeType": "text/html",
        "description": "HTML Artifact"
      },
      {
        "ext": ["svg"],
        "mimeType": "image/svg+xml",
        "description": "SVG Artifact"
      },
      {
        "ext": ["md"],
        "mimeType": "text/markdown",
        "description": "Markdown Artifact"
      },
      {
        "ext": ["mermaid"],
        "mimeType": "text/plain",
        "description": "Mermaid Diagram"
      }
    ]
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:stele.db"]
    }
  }
}
