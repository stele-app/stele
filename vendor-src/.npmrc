# vendor-src is consumed by scripts/prebuild-deps.ts via direct filesystem
# paths (e.g. vendor-src/node_modules/react). The prebuild expects packages
# to live directly under node_modules/, not under .pnpm/ symlinks.
# Force the hoisted node_modules layout so pnpm v10+ behaves like older
# versions / npm — same path on every machine and on Vercel.
node-linker=hoisted
